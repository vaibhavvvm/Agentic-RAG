# ============================================================
# RAG Environment Variables — copy to .env and fill in values
# ============================================================

# ----- Application -----
APP_NAME=RAG
APP_VERSION=1.0.0
ENVIRONMENT=development          # development | staging | production
DEBUG=false

# ----- PostgreSQL / pgvector -----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=rag
POSTGRES_VECTOR_DIM=768
POSTGRES_POOL_MIN_SIZE=2
POSTGRES_POOL_MAX_SIZE=10
POSTGRES_BM25_WEIGHT=0.3
POSTGRES_VECTOR_WEIGHT=0.7

# ----- Neo4j -----
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j
NEO4J_DATABASE=neo4j
NEO4J_MAX_HOP_DEPTH=3
NEO4J_GRAPHITI_EPISODE_LIMIT=10

# ----- Groq (primary LLM) -----
# Single key shortcut:
GROQ_API_KEY=gsk_...
# OR multi-key rotation (comma-separated):
# GROQ_API_KEYS=gsk_key1,gsk_key2,gsk_key3
GROQ_PRIMARY_MODEL=llama3-70b-8192
GROQ_FAST_MODEL=llama3-8b-8192
GROQ_MAX_RETRIES=5
GROQ_RETRY_BASE_DELAY=1.0
GROQ_RETRY_MAX_DELAY=60.0
GROQ_TEMPERATURE=0.1
GROQ_MAX_TOKENS=2048

# ----- Ollama (embeddings + reranking + vision) -----
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_RERANKER_MODEL=bge-reranker-v2-m3
OLLAMA_VISION_MODEL=llava:13b
OLLAMA_CHAT_MODEL=llama3:8b
OLLAMA_TIMEOUT=300

# ----- Memory -----
MEMORY_WINDOW_SIZE=10
MEMORY_FAISS_INDEX_PATH=data/faiss_episodic
MEMORY_FAISS_TOP_K=5
MEMORY_SUMMARISE_AFTER_TURNS=8
MEMORY_GRAPH_MEMORY_TOP_K=5

# ----- Retrieval -----
RETRIEVAL_TOP_K_VECTOR=10
RETRIEVAL_TOP_K_GRAPH=5
RETRIEVAL_TOP_K_RERANK=5
RETRIEVAL_TOP_K_FINAL=3
RETRIEVAL_SELF_REFLECTION_ENABLED=true
RETRIEVAL_SELF_REFLECTION_THRESHOLD=0.6
RETRIEVAL_MAX_REFLECTION_ROUNDS=2
RETRIEVAL_QUERY_EXPANSION_ENABLED=true
RETRIEVAL_NUM_EXPANDED_QUERIES=3
RETRIEVAL_CACHE_TTL_SECONDS=3600
RETRIEVAL_CACHE_MAX_SIZE=512
RETRIEVAL_RRF_K=60

# ----- Chunking -----
CHUNK_SEMANTIC_BREAKPOINT_PERCENTILE=95.0
CHUNK_SEMANTIC_MIN_CHUNK_SIZE=100
CHUNK_SEMANTIC_MAX_CHUNK_SIZE=1500
CHUNK_CONTEXT_WINDOW=512
CHUNK_PARENT_CHUNK_SIZE=2000
CHUNK_CHILD_CHUNK_SIZE=400
CHUNK_CHILD_CHUNK_OVERLAP=80

# ----- Router -----
ROUTER_KEYWORD_CONFIDENCE_THRESHOLD=0.4
# ROUTER_ARBITER_MODEL=           # leave blank to use GROQ_FAST_MODEL

# ----- Monitoring -----
MONITORING_LOG_LEVEL=INFO        # DEBUG | INFO | WARNING | ERROR | CRITICAL
MONITORING_LOG_FORMAT=json       # json | text
# MONITORING_LOG_FILE=logs/rag.log
MONITORING_METRICS_ENABLED=true
# MONITORING_METRICS_EXPORT_PATH=data/metrics_snapshot.json
